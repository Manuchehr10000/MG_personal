# Copy to backend/.env and adjust. Secrets never live in code (principle 10).

# Dev: SQLite file. Prod: Postgres, e.g.
#   postgresql+psycopg://user:pass@host:5432/ghafforzoda
DATABASE_URL=sqlite:///./dev.db

# dev | prod
ENVIRONMENT=dev

# Absolute path to the Vite build output. Defaults to ../frontend/dist if unset.
# FRONTEND_DIST=/abs/path/to/frontend/dist
