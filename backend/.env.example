# Copy to backend/.env and adjust. Secrets never live in code (principle 10).

# Dev: SQLite file. Prod: Postgres, e.g.
#   postgresql+psycopg://user:pass@host:5432/ghafforzoda
DATABASE_URL=sqlite:///./dev.db

# dev | prod
ENVIRONMENT=dev

# Absolute path to the Vite build output. Defaults to ../frontend/dist if unset.
# FRONTEND_DIST=/abs/path/to/frontend/dist

# Owner-notification email gateway (008). Provider-agnostic transactional-email
# API reached via httpx. Choose the concrete provider + verify Tajikistan/CIS
# deliverability at deploy (a deploy decision, like the Bunny playback test).
# Leave blank to disable sending — submissions still store (store-and-forward).
EMAIL_API_BASE_URL=
EMAIL_API_KEY=
EMAIL_FROM=
EMAIL_OWNER_TO=
